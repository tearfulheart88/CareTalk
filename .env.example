# 돌봄톡 (CareTalk) MCP 서버 - 환경 변수 설정
# ==============================================
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
#   cp .env.example .env
#
# ⚠️ .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore에 추가 필수)

# ── OpenAI API 키 (실제 GPT 연동 시 필요) ───────────────────────
# GPT-4o-mini API 호출용. https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=2.2
OPENAI_MAX_OUTPUT_TOKENS=800

# ── 카카오 API 키 (선택) ───────────────────────────────────────
# MCP 서버와 공개 저장소에는 개인 키를 넣지 않습니다. 아래 키는 별도 로그인 또는
# 계약한 비즈메시지 공급사 어댑터를 운영할 때 그 비공개 환경에만 설정합니다.
# 카카오 로그인 REST API 키. https://developers.kakao.com 에서 발급
KAKAO_REST_API_KEY=

# 카카오 로그인 Client Secret (선택 사항)
KAKAO_CLIENT_SECRET=

# 카카오 비즈메시지/알림톡 연동 키 (알림톡 실제 발송 시 필요)
KAKAO_BIZ_API_KEY=
KAKAO_SENDER_KEY=
KAKAO_BIZ_API_URL=

# ── MCP 서버 설정 ───────────────────────────────────────────────
# 서버 포트 (기본 9000, 8000번대 금지)
MCP_PORT=9000
# 배포 플랫폼이 PORT를 주입하면 MCP_PORT를 비워 두고 PORT 값을 사용해도 됩니다.

# 공개 배포의 안전 기본값: 키가 있어도 아래 두 조건을 모두 명시해야 실제 호출됩니다.
MOCK_MODE=true
LIVE_API_ENABLED=false

# ── 공개 API 사용량 보호 ────────────────────────────────────────
DAILY_QUOTA_ENABLED=true
OPENAI_DAILY_LIMIT=100
OPENAI_RATE_LIMIT_PER_MINUTE=10
OPENAI_MAX_CONCURRENCY=2

# ── 데이터베이스 설정 ───────────────────────────────────────────
# SQLite 데이터베이스 파일 경로 (기본값: ./db/caretalk.db)
CARETALK_DB_PATH=./db/caretalk.db
# 사용량 테이블을 별도 DB에 둘 때만 지정 (미지정 시 CARETALK_DB_PATH 사용)
CARETALK_USAGE_DB_PATH=

# ── 예약 worker와 승인된 외부 전달 게이트웨이 ──────────────────
# worker는 동의된 예약 질문·가족 요약·활동 부재 확인을 주기적으로 대기열에 만듭니다.
CARE_WORKER_ENABLED=true
CARE_WORKER_INTERVAL_SECONDS=30
CARE_WORKER_BATCH_SIZE=50
CARE_WORKER_LEASE_SECONDS=90
CARE_WORKER_MAX_ATTEMPTS=5
CARE_WORKER_RETRY_BASE_SECONDS=30

# outbox: DB 대기열에만 안전하게 저장(로컬 검증 기본값)
# webhook: 아래 HTTPS 게이트웨이로 HMAC-SHA256 서명해 실제 전달
CARETALK_DELIVERY_MODE=outbox
CARETALK_DELIVERY_WEBHOOK_URL=
# 최소 32바이트 무작위 비밀키. 저장소에 커밋하지 않습니다.
CARETALK_DELIVERY_WEBHOOK_SECRET=
CARETALK_DELIVERY_TIMEOUT_SECONDS=3
# 로컬 테스트 전용. 공개 배포에서는 반드시 false입니다.
CARETALK_ALLOW_INSECURE_LOCAL_WEBHOOK=false

# ── 로깅 설정 ───────────────────────────────────────────────────
# 로그 레벨: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
