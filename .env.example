# 돌봄톡 (CareTalk) MCP 서버 - 환경 변수 설정
# ==============================================
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
#   cp .env.example .env
#
# ⚠️ .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore에 추가 필수)

# ── OpenAI API 키 (실제 GPT 연동 시 필요) ───────────────────────
# GPT-4o-mini API 호출용. https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=2.2
OPENAI_MAX_OUTPUT_TOKENS=800

# ── 카카오 API 키 (본선 연동 시 필요) ──────────────────────────
# 아래 카카오 키는 services/의 연동 어댑터를 별도 사용할 때만 필요합니다.
# 현재 MCP Tool은 실제 로그인이나 알림톡 발송을 자동 수행하지 않습니다.
# 카카오 로그인 REST API 키. https://developers.kakao.com 에서 발급
KAKAO_REST_API_KEY=

# 카카오 로그인 Client Secret (선택 사항)
KAKAO_CLIENT_SECRET=

# 카카오 비즈메시지/알림톡 연동 키 (알림톡 실제 발송 시 필요)
KAKAO_BIZ_API_KEY=
KAKAO_SENDER_KEY=

# ── MCP 서버 설정 ───────────────────────────────────────────────
# 서버 포트 (기본 9000, 8000번대 금지)
MCP_PORT=9000
# 배포 플랫폼이 PORT를 주입하면 MCP_PORT를 비워 두고 PORT 값을 사용해도 됩니다.

# 공개 배포의 안전 기본값: 키가 있어도 아래 두 조건을 모두 명시해야 실제 호출됩니다.
MOCK_MODE=true
LIVE_API_ENABLED=false

# ── 공개 API 사용량 보호 ────────────────────────────────────────
DAILY_QUOTA_ENABLED=true
OPENAI_DAILY_LIMIT=100
OPENAI_RATE_LIMIT_PER_MINUTE=10
OPENAI_MAX_CONCURRENCY=2

# ── 데이터베이스 설정 ───────────────────────────────────────────
# SQLite 데이터베이스 파일 경로 (기본값: ./db/caretalk.db)
CARETALK_DB_PATH=./db/caretalk.db
# 사용량 테이블을 별도 DB에 둘 때만 지정 (미지정 시 CARETALK_DB_PATH 사용)
CARETALK_USAGE_DB_PATH=

# ── 로깅 설정 ───────────────────────────────────────────────────
# 로그 레벨: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
